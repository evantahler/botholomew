{
  "name": "botholomew",
  "version": "0.18.8",
  "description": "An autonomous AI agent for knowledge work — works your task queue while you sleep.",
  "type": "module",
  "bin": {
    "botholomew": "./src/cli.ts",
    "bothy": "./src/cli.ts"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/evantahler/botholomew.git"
  },
  "scripts": {
    "dev": "bun run src/cli.ts -d .botholomew",
    "dev:demo": "bun run src/cli.ts chat -p 'learn everything you can about me from the connected MCP services and then save what you'\\''ve learned about me to context'",
    "test": "bun test",
    "lint": "tsc --noEmit && biome check .",
    "capture": "bun run scripts/capture.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@evantahler/mcpx": "0.21.9",
    "ansis": "^4.3.0",
    "commander": "^14.0.3",
    "gray-matter": "^4.0.3",
    "ink": "^7.0.3",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "istextorbinary": "^9.5.0",
    "membot": "^0.17.0",
    "nanospinner": "^1.2.2",
    "react": "^19.2.6",
    "uuid": "^14.0.0",
    "wrap-ansi": "^10.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.14",
    "@types/uuid": "^11.0.0",
    "typescript": "^6.0.3",
    "vitepress": "^1.6.4",
    "vitepress-plugin-llms": "^1.12.2",
    "vue": "^3.5.34"
  },
